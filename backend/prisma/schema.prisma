generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)

  purchases       Purchase[]
  createdVehicles Vehicle[]  @relation("CreatedVehicles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Vehicle {
  id          String   @id @default(cuid())

  make        String
  model       String
  categoryId  String

  price       Decimal  @db.Decimal(10,2)
  quantity    Int      @default(0)
  description String?

  createdById String?
  createdBy   User?    @relation("CreatedVehicles", fields: [createdById], references: [id], onDelete: SetNull)

  purchases   Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@index([make])
  @@index([model])
  @@index([categoryId])
  @@index([price])
  @@index([createdById])
  @@unique([make, model, categoryId])
}


model Purchase {
  id          String @id @default(cuid())

  userId      String
  vehicleId   String

  quantity    Int @default(1)
  totalPrice  Decimal @db.Decimal(10,2)

  user        User    @relation(fields: [userId], references: [id])
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([vehicleId])
}
